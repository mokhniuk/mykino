# MyKino AI Proxy Server — Environment Variables
# Copy to .env and uncomment ONE AI provider.

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Uncomment exactly ONE:

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
MISTRAL_API_KEY=your-key-here
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: override the default model for the chosen provider
# AI_MODEL=mistral-small-latest

# ─── Stripe (optional — enables Pro subscriptions) ───────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...    ← from Stripe dashboard → Webhooks
# STRIPE_PRICE_MONTHLY=price_...     ← monthly recurring price ID
# STRIPE_PRICE_ANNUAL=price_...      ← annual recurring price ID

# ─── Supabase (required when Stripe is enabled) ───────────────────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   ← Settings → API → service_role key (keep secret!)

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# Origin allowed to call this proxy (use your domain in production)
# ALLOWED_ORIGIN=https://mykino.app

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Requests per day for unauthenticated (free) users. Ignored in community mode.
FREE_DAILY_LIMIT=3

# Set to true to disable rate limiting (self-hosted / community deployments)
# COMMUNITY_MODE=true
